# 复制本文件为 .env 并填入你的真实配置

# === 必填 ===
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# === DeepSeek 接口（OpenAI 兼容，一般无需改动）===
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型选择：
#   deepseek-chat      —— V3，支持工具调用（本框架默认，推荐）
#   deepseek-reasoner  —— R1，推理强但【不支持工具调用】，切到它工具会失效
DEEPSEEK_MODEL=deepseek-chat

# === Loop 层调优 ===
AGENT_MAX_STEPS=10
AGENT_TEMPERATURE=0.7
AGENT_TIMEOUT=60
